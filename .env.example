# Copy to .env and fill in (never commit .env)

# ── Repository paths ─────────────────────────────────────────────
# FR_TOOLS_REPO=/path/to/fr-tools

# ── Data layout（默认：data/source + data/sink/map）────────────────
# DATA_SOURCE_DIR=
# DATA_SINK_MAP_ROOT=              # 默认 data/sink/map/农业基地-大疆测绘

# ── GeoJSON generation ─────────────────────────────────────────
GEOJSON_VERSION=农业基地_v7.4_GCJ02_L3_SingleMap

# 可选：覆盖单次输出（pytest 用临时目录）
# GEOJSON_OUTPUT_DIR=

# v2 对账 sidecar 输出（默认 sink/.../农业基地_v2_WGS84）
# GEOJSON_WGS84_DIR=

# 1=跳过 MySQL
GEOJSON_SKIP_DB=0
GEOJSON_SKIP_DB_UPDATE=0

# 1=不覆盖已有 .json（封板 / 已部署目录）
GEOJSON_PROTECT_EXISTING=1

# ── Source overrides ─────────────────────────────────────────────
# KML_DIR=
# EXCEL_PATH=

# ── FineReport 部署（同步 sink 目标，非生成默认路径）────────────
FINEREPORT_WEBINF=/Applications/FineReport/webapps/webroot/WEB-INF
GEOJSON_MAP_SUBDIR=assets/map/geographic/农业基地-大疆测绘

# ── MySQL ────────────────────────────────────────────────────────
MYSQL_HOST=172.17.4.4
MYSQL_PORT=3310
MYSQL_USER=bigdata
MYSQL_PASSWORD=
MYSQL_DATABASE=yxg_bigscreen
