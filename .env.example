# Copy to .env and fill in (never commit .env)

# ── Repository paths ─────────────────────────────────────────────
# FR_TOOLS_REPO=/path/to/fr-tools

# ── Data layout（默认：data/source + data/sink）────────────────────
# DATA_SOURCE_DIR=
# DATA_SINK_ROOT=                  # 默认 data/sink（五版本目录在其下）
# DATA_SINK_MAP_ROOT=              # 兼容旧名，同 DATA_SINK_ROOT

# ── GeoJSON generation ─────────────────────────────────────────
GEOJSON_VERSION=农业基地_v7.4_GCJ02_L3_SingleMap

# 可选：覆盖单次输出（pytest 用临时目录）
# GEOJSON_OUTPUT_DIR=
# GEOJSON_BASES=重庆酉阳          # 仅生成指定基地（逗号分隔），不改动其余基地 sink 文件

# v2 对账 sidecar 输出（默认 sink/.../农业基地_v2_WGS84）
# GEOJSON_WGS84_DIR=

# 1=跳过 MySQL
GEOJSON_SKIP_DB=0
GEOJSON_SKIP_DB_UPDATE=0

# 1=不覆盖已有 .json（封板 / 已部署目录）
GEOJSON_PROTECT_EXISTING=1

# ── Source overrides（默认在 data/source/）──────────────────────
# KML_DIR=                         # → data/source/1.农业基地KML
# EXCEL_PATH=                      # → data/source/农业资产盘点明细.xlsx

# ── FineReport 部署（同步 sink 目标，非生成默认路径）────────────
FINEREPORT_WEBINF=/Applications/FineReport/webapps/webroot/WEB-INF
GEOJSON_MAP_SUBDIR=assets/map/geographic/农业基地-大疆测绘

# ── MySQL ────────────────────────────────────────────────────────
MYSQL_HOST=172.17.4.4
MYSQL_PORT=3310
MYSQL_USER=bigdata
MYSQL_PASSWORD=
MYSQL_DATABASE=yxg_bigscreen
