# Copy to .env and fill in (never commit .env)

# ── Repository paths ─────────────────────────────────────────────
# FR_TOOLS_REPO=/path/to/fr-tools

# ── FineReport deployment ────────────────────────────────────────
FINEREPORT_WEBINF=/Applications/FineReport/webapps/webroot/WEB-INF
GEOJSON_MAP_SUBDIR=assets/map/geographic/农业基地-大疆测绘

# WGS84 对账目录（world 前缀历史路径）
GEOJSON_WGS84_SUBDIR=assets/map/geographic/world/农业基地-大疆测绘/农业基地_v2_WGS84

# ── GeoJSON generation ─────────────────────────────────────────
# 活跃版本目录名（须与 WEB-INF 下目录名一致）
GEOJSON_VERSION=农业基地_v7.4_GCJ02_L3_SingleMap

# 可选：覆盖完整输出目录（测试用 tests/.tmp/out）
# GEOJSON_OUTPUT_DIR=

# 1=跳过 MySQL 查询与 DB 更新（测试 / 离线）
GEOJSON_SKIP_DB=0
GEOJSON_SKIP_DB_UPDATE=0

# 1=若目标 .json 已存在则跳过写入（保护封板 GeoJSON，默认 1）
GEOJSON_PROTECT_EXISTING=1

# ── Source data（默认相对仓库 data/）────────────────────────────
# KML_DIR=
# EXCEL_PATH=

# ── MySQL（ods_ag_base_v2）──────────────────────────────────────
MYSQL_HOST=172.17.4.4
MYSQL_PORT=3310
MYSQL_USER=bigdata
MYSQL_PASSWORD=
MYSQL_DATABASE=yxg_bigscreen
